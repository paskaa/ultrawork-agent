  "categoryMapping": {
    "visual-engineering": {
      "primary": "Qwen-Coder-Qoder-1.0",
      "fallback": ["Qwen3.5-Plus", "Kimi-K2.5"],
      "reason": "Qwen Coder Qoder 专为编码优化，适合前端开发"
    },
    "deep": {
      "primary": "GLM-5",
      "fallback": ["Qwen3.5-Plus", "Kimi-K2.5"],
      "reason": "GLM-5 擅长复杂系统工程和长期任务"
    },
    "quick": {
      "primary": "Qwen-Coder-Qoder-1.0",
      "fallback": ["MiniMax-M2.5"],
      "reason": "快速任务使用成本最低的编码模型"
    },
    "ultrabrain": {
      "primary": "GLM-5",
      "fallback": ["Qwen3.5-Plus", "Kimi-K2.5"],
      "reason": "复杂决策使用 GLM-5 强推理能力"
    },
    "review": {
      "primary": "Qwen-Coder-Qoder-1.0",
      "fallback": ["Qwen3.5-Plus"],
      "reason": "代码审查使用编码专用模型"
    }
  },

  "routingRules": [
    {
      "condition": "model.available === true",
      "action": "use primary model"
    },
    {
      "condition": "model.available === false",
      "action": "fallback to first available model in fallback list"
    },
    {
      "condition": "no available models",
      "action": "use defaultModel"
    }
  ],

  "costOptimization": {
    "enabled": true,
    "rules": [
      {
        "category": "quick",
        "preferCheapest": true
      },
      {
        "category": "deep",
        "preferCheapest": false,
        "considerQuality": true
      },
      {
        "category": "ultrabrain",
        "preferCheapest": false,
        "considerQuality": true
      }
    ]
  }
}
