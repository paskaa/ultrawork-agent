{
  "name": "ultrawork-panel",
  "version": "5.0.0",
  "description": "UltraWork 三国军团 Web 面板 - Session 多会话管理",
  "main": "./scripts/ultrawork-wrapper.js",
  "author": "UltraWork",
  "license": "MIT",
  
  "config": {
    "port": 3459,
    "defaultSession": "default",
    "autoStart": false,
    "autoReport": true,
    "reportInterval": 5000
  },
  
  "commands": {
    "panel:start": {
      "description": "启动 Web 面板服务器",
      "script": "cd \"{{pluginDir}}\\scripts\" && start //b node state-server-v5.cjs",
      "windows": "cd \"{{pluginDir}}\\scripts\" && start //b node state-server-v5.cjs",
      "macos": "cd {{pluginDir}}/scripts && node state-server-v5.cjs &",
      "linux": "cd {{pluginDir}}/scripts && node state-server-v5.cjs &"
    },
    "panel:stop": {
      "description": "停止 Web 面板服务器",
      "script": "taskkill /F /IM node.exe 2>nul || true",
      "windows": "taskkill /F /IM node.exe 2>nul || true",
      "macos": "pkill -f state-server-v5.cjs || true",
      "linux": "pkill -f state-server-v5.cjs || true"
    },
    "panel:open": {
      "description": "在浏览器中打开 Web 面板",
      "script": "start http://localhost:{{config.port}}",
      "windows": "start http://localhost:{{config.port}}",
      "macos": "open http://localhost:{{config.port}}",
      "linux": "xdg-open http://localhost:{{config.port}}"
    },
    "panel:status": {
      "description": "检查面板服务器状态",
      "script": "curl -s http://localhost:{{config.port}}/api/sessions | head -c 200"
    },
    "panel:session:create": {
      "description": "创建新的 Session",
      "script": "curl -s -X POST http://localhost:{{config.port}}/api/sessions -H \"Content-Type: application/json\" -d \"{\\\"name\\\":\\\"{{name}}\\\"}\"",
      "args": ["name"]
    },
    "panel:session:list": {
      "description": "列出所有 Sessions",
      "script": "curl -s http://localhost:{{config.port}}/api/sessions | jq -r '.sessions[] | \"\\(.id): \\(.name) [\\(.status)] - \\(.activeAgents)人活跃\"'"
    },
    "panel:session:switch": {
      "description": "切换到指定 Session",
      "script": "echo '请在浏览器中访问: http://localhost:{{config.port}}?session={{sessionId}}'",
      "args": ["sessionId"]
    },
    "panel:report:status": {
      "description": "报告任务状态",
      "script": "node -e \"const u=require('{{pluginDir}}/scripts/ultrawork-reporter'); u.setSession('{{session}}'); u.report('{{status}}', '{{task}}', {{progress}}).then(r=>console.log(r))\"",
      "args": ["session", "status", "task", "progress"]
    },
    "panel:report:assign": {
      "description": "分配将领",
      "script": "node -e \"const u=require('{{pluginDir}}/scripts/ultrawork-reporter'); u.setSession('{{session}}'); u.assign('{{agent}}', '{{task}}', {{progress}}).then(r=>console.log(r))\"",
      "args": ["session", "agent", "task", "progress"]
    },
    "panel:report:log": {
      "description": "推送日志",
      "script": "node -e \"const u=require('{{pluginDir}}/scripts/ultrawork-reporter'); u.setSession('{{session}}'); u.log('{{agent}}', '{{agentName}}', '{{message}}').then(r=>console.log(r))\"",
      "args": ["session", "agent", "agentName", "message"]
    },
    "panel:example:bugfix": {
      "description": "运行修复 Bug 示例",
      "script": "cd \"{{pluginDir}}\\scripts\" && node ultrawork-example.js bugfix"
    },
    "panel:example:refactor": {
      "description": "运行重构示例",
      "script": "cd \"{{pluginDir}}\\scripts\" && node ultrawork-example.js refactor"
    }
  },
  
  "hooks": {
    "onLoad": {
      "description": "插件加载时检查面板状态",
      "action": "checkStatus"
    },
    "onTaskStart": {
      "description": "任务开始时自动推送",
      "condition": "{{config.autoReport}}",
      "action": "reportTaskStart"
    },
    "onTaskEnd": {
      "description": "任务结束时自动推送",
      "condition": "{{config.autoReport}}",
      "action": "reportTaskEnd"
    }
  },
  
  "agents": {
    "zhugeliang": { "name": "诸葛亮", "role": "主帅", "model": "GLM-5" },
    "zhouyu": { "name": "周瑜", "role": "大都督", "model": "GLM-5" },
    "zhaoyun": { "name": "赵云", "role": "大将", "model": "Qwen3.5-Plus" },
    "simayi": { "name": "司马懿", "role": "大将", "model": "MiniMax-M2.5" },
    "guanyu": { "name": "关羽", "role": "大将", "model": "Qwen3.5-Plus" },
    "zhangfei": { "name": "张飞", "role": "大将", "model": "MiniMax-M2.5" },
    "machao": { "name": "马超", "role": "大将", "model": "GLM-5" },
    "huangzhong": { "name": "黄忠", "role": "大将", "model": "Qwen3.5-Plus" }
  },
  
  "api": {
    "endpoints": [
      { "path": "/", "method": "GET", "description": "Web 面板首页" },
      { "path": "/api/sessions", "method": "GET", "description": "获取所有 Sessions" },
      { "path": "/api/sessions", "method": "POST", "description": "创建新 Session" },
      { "path": "/api/sessions/recent", "method": "GET", "description": "获取最近5个活跃 Sessions" },
      { "path": "/api/sessions/:id", "method": "DELETE", "description": "删除 Session" },
      { "path": "/api/status", "method": "GET", "description": "获取当前 Session 状态" },
      { "path": "/api/task/status", "method": "POST", "description": "更新任务状态" },
      { "path": "/api/task/progress", "method": "POST", "description": "更新任务进度" },
      { "path": "/api/task/complete", "method": "POST", "description": "完成任务" },
      { "path": "/api/agents/:id", "method": "POST", "description": "更新将领状态" },
      { "path": "/api/logs", "method": "POST", "description": "添加日志" },
      { "path": "/ws", "method": "WS", "description": "WebSocket 实时通信" }
    ]
  },
  
  "scripts": {
    "test": "node scripts/ultrawork-example.js bugfix",
    "example:bugfix": "node scripts/ultrawork-example.js bugfix",
    "example:refactor": "node scripts/ultrawork-example.js refactor",
    "status": "curl -s http://localhost:3459/api/sessions",
    "reset": "taskkill /F /IM node.exe 2>nul && echo '面板已停止'"
  },
  
  "documentation": {
    "readme": "./SKILL.md",
    "changelog": "./CHANGELOG.md",
    "examples": "./scripts/ultrawork-example.js"
  },
  
  "environment": {
    "ULTRAWORK_PORT": { "description": "Web 面板端口", "default": 3459 },
    "ULTRAWORK_SESSION": { "description": "默认 Session ID", "default": "default" },
    "ULTRAWORK_AUTO_REPORT": { "description": "自动报告状态", "default": "true" }
  },
  
  "quickStart": {
    "steps": [
      {
        "step": 1,
        "action": "启动面板",
        "command": "panel:start"
      },
      {
        "step": 2,
        "action": "打开浏览器查看",
        "command": "panel:open"
      },
      {
        "step": 3,
        "action": "运行示例",
        "command": "panel:example:bugfix"
      },
      {
        "step": 4,
        "action": "在代码中集成",
        "code": "const { init, startTask, assignAgent } = require('./plugins/ultrawork-sanguo/scripts/ultrawork-wrapper');"
      }
    ]
  }
}
