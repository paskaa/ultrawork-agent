  "categoryMapping": {
    "visual-engineering": {
      "primary": "claude-sonnet-4-20250514",
      "fallback": ["claude-3-5-sonnet-20241022"],
      "reason": "Sonnet 系列擅长前端开发"
    },
    "deep": {
      "primary": "claude-sonnet-4-20250514",
      "fallback": ["claude-opus-4-20250514"],
      "reason": "深度任务使用 Sonnet 4，复杂任务可用 Opus 4"
    },
    "quick": {
      "primary": "claude-sonnet-4-20250514",
      "fallback": ["claude-3-5-haiku-20241022"],
      "reason": "快速任务优先使用 Haiku"
    },
    "ultrabrain": {
      "primary": "claude-opus-4-20250514",
      "fallback": ["claude-sonnet-4-20250514"],
      "reason": "复杂决策使用最强推理模型"
    },
    "review": {
      "primary": "claude-sonnet-4-20250514",
      "fallback": ["claude-3-5-sonnet-20241022"],
      "reason": "代码审查使用平衡型模型"
    }
  },

  "routingRules": [
    {
      "condition": "model.available === true",
      "action": "use primary model"
    },
    {
      "condition": "model.available === false",
      "action": "fallback to first available model in fallback list"
    },
    {
      "condition": "no available models",
      "action": "use defaultModel"
    }
  ],

  "costOptimization": {
    "enabled": true,
    "rules": [
      {
        "category": "quick",
        "preferCheapest": true
      },
      {
        "category": "deep",
        "preferCheapest": false,
        "considerQuality": true
      },
      {
        "category": "ultrabrain",
        "preferCheapest": false,
        "considerQuality": true
      }
    ]
  }
}
